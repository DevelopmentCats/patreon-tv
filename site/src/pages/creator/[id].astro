---
// src/pages/creator/[id].astro
// Deep-link fallback for creator pages.

import Base from "../../layouts/Base.astro";

export const prerender = false;

const { id } = Astro.params;
if (!id || !/^\d+$/.test(id)) {
  return Astro.redirect("/", 302);
}

const deepLink = `patreontv://creator/${id}`;
---

<Base
  title="Open creator"
  description="Open this creator's page in PatreonTV."
>
  <div style="text-align: center; padding: 40px 0;">
    <h1>Open creator</h1>
    <p style="max-width: 480px; margin: 0 auto 40px;">
      Tap below to jump straight to this creator in PatreonTV on your
      Apple TV.
    </p>

    <div
      style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;"
    >
      <a class="btn" href={deepLink}>Open in PatreonTV</a>
      <a class="btn secondary" href="/">Get PatreonTV</a>
    </div>
  </div>
</Base>
