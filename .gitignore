# ============================================================
# Anything under .internal/ is workspace-only. AI-generated
# research, planning, scraped reference material, and live-test
# fixtures live there. Never committed.
# ============================================================
.internal/

# Agent skills are workspace tooling, not app code. skills/ holds
# the vendored content; .agents/skills/ symlinks into it for
# auto-loading. Both stay local-only.
skills/
.agents/

