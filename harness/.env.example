# Patreon OAuth client credentials — get these from
# https://www.patreon.com/portal/registration/register-clients
#
# You need to register a V2 client. Set the redirect URI in the Patreon
# portal to exactly: http://localhost:8721/callback
#
# Copy this file to `.env` and fill in real values.

PATREON_CLIENT_ID=
PATREON_CLIENT_SECRET=
PATREON_REDIRECT_URI=http://localhost:8721/callback

# The scopes to request. For the "fan" test we want to see what a
# user-signed-in-to-consume flow returns. For the "creator" test we
# want the full creator-side surface so we can inspect posts, members,
# and the shape of video content in real posts.
#
# Fan scopes (what our TV app will use for end-user sign-in):
FAN_SCOPES=identity identity[email] identity.memberships campaigns

# Creator scopes (what a participating-creator authorization would grant):
CREATOR_SCOPES=identity identity[email] identity.memberships campaigns campaigns.members campaigns.members[email] campaigns.posts w:campaigns.webhook

# Optional: a specific campaign_id to probe if you already know one.
# Otherwise the probe will use the campaign_id from /identity include=campaign.
PROBE_CAMPAIGN_ID=

# Optional: a specific post ID to fetch, if you want to inspect video content.
PROBE_POST_ID=

# User-Agent — Patreon rejects requests without a descriptive UA.
USER_AGENT=PatreonTVResearch/0.1 (contact: [email protected])
